{
  "version": 2,
  "name": "deep-neural-networks-course",
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/module%201/(.*)",
      "dest": "/module 1/$1"
    },
    {
      "src": "/module%202/(.*)",
      "dest": "/module 2/$1"
    },
    {
      "src": "/module%203/(.*)",
      "dest": "/module 3/$1"
    },
    {
      "src": "/module%204/(.*)",
      "dest": "/module 4/$1"
    },
    {
      "src": "/module%205/(.*)",
      "dest": "/module 5/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
